#!/usr/bin/env bash
# UserPromptSubmit hook — Injects session context on every prompt.
# Survives context compaction by re-injecting from disk.
# Error-tolerant: always exits 0.
# Design: docs/plans/2026-03-06-wal-session-notes-design.md

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

_do_context() {
    set -euo pipefail

    source "$SCRIPT_DIR/wal-lib.sh"

    wal_read_stdin
    wal_parse_fields

    [ "$WAL_SESSION_ID" = "unknown" ] && exit 0

    # Find rawgentic workspace
    wal_find_workspace || exit 0

    # Resolve claude_docs path from workspace config
    wal_resolve_claude_docs

    # Write session ID to discoverable file for /rawgentic:switch skill
    mkdir -p "$WAL_CLAUDE_DOCS" 2>/dev/null || true
    printf '%s' "$WAL_SESSION_ID" > "$WAL_CLAUDE_DOCS/.current_session_id" 2>/dev/null || true

    REGISTRY_FILE="$WAL_CLAUDE_DOCS/session_registry.jsonl"
    WAL_FILE="$WAL_CLAUDE_DOCS/wal.jsonl"
    NOTES_DIR="$WAL_CLAUDE_DOCS/session_notes"

    # --- Lookup project from registry ---
    wal_resolve_project

    # If not registered, use detection cascade
    if [ -z "$WAL_PROJECT" ]; then
        # Count active projects
        ACTIVE_COUNT=$("$WAL_JQ" '[.projects[] | select(.active == true)] | length' "$WAL_WORKSPACE_FILE" 2>/dev/null || echo "0")

        if [ "$ACTIVE_COUNT" -eq 0 ]; then
            "$WAL_JQ" -nc --arg ctx "No active projects in workspace. Use /rawgentic:new-project to set one up." \
                '{additionalContext: $ctx}'
            exit 0
        elif [ "$ACTIVE_COUNT" -eq 1 ]; then
            # Single active project — auto-bind
            ACTIVE_PROJECT=$("$WAL_JQ" -r '.projects[] | select(.active == true) | .name' "$WAL_WORKSPACE_FILE" 2>/dev/null || true)
            ACTIVE_PATH=$("$WAL_JQ" -r '.projects[] | select(.active == true) | .path' "$WAL_WORKSPACE_FILE" 2>/dev/null || true)

            if [ -n "$ACTIVE_PROJECT" ]; then
                # Auto-register this session for the active project
                mkdir -p "$WAL_CLAUDE_DOCS/session_notes"
                TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
                "$WAL_JQ" -nc \
                    --arg sid "$WAL_SESSION_ID" \
                    --arg proj "$ACTIVE_PROJECT" \
                    --arg ppath "$ACTIVE_PATH" \
                    --arg ts "$TS" \
                    --arg cwd "$WAL_CWD" \
                    '{session_id:$sid, project:$proj, project_path:$ppath, started:$ts, cwd:$cwd}' \
                    >> "$REGISTRY_FILE" 2>/dev/null || true

                # Initialize session notes file if missing
                NOTES_FILE="$NOTES_DIR/${ACTIVE_PROJECT}.md"
                if [ ! -f "$NOTES_FILE" ]; then
                    mkdir -p "$NOTES_DIR"
                    printf '# Session Notes -- %s\n' "$ACTIVE_PROJECT" > "$NOTES_FILE"
                fi

                WAL_PROJECT="$ACTIVE_PROJECT"
                WAL_PROJECT_PATH="$ACTIVE_PATH"
            fi
        else
            # Multiple active projects — prompt user to bind
            ACTIVE_NAMES=$("$WAL_JQ" -r '[.projects[] | select(.active == true) | .name] | join(", ")' "$WAL_WORKSPACE_FILE" 2>/dev/null || true)
            "$WAL_JQ" -nc --arg ctx "Multiple projects active: ${ACTIVE_NAMES}. Use /rawgentic:switch <name> to bind this session to a project." \
                '{additionalContext: $ctx}'
            exit 0
        fi
    fi

    # --- Resolve protection level ---
    wal_resolve_protection_level

    CONTEXT="SESSION CONTEXT [${WAL_PROJECT} | ${WAL_SESSION_ID} | ${WAL_PROTECTION_LEVEL}]:"

    # --- Session notes status ---
    NOTES_FILE="$NOTES_DIR/${WAL_PROJECT}.md"
    if [ -f "$NOTES_FILE" ]; then
        # Find last session header for this session_id
        LAST_HEADER=$(grep "ID: ${WAL_SESSION_ID}" "$NOTES_FILE" 2>/dev/null | tail -1 || true)
        if [ -n "$LAST_HEADER" ]; then
            # Extract task from nearby lines
            TASK_LINE=$(grep -A2 "ID: ${WAL_SESSION_ID}" "$NOTES_FILE" 2>/dev/null | grep "^## Task:" | tail -1 || true)
            TASK="${TASK_LINE#*## Task: }"
            [ -z "$TASK" ] && TASK="(unknown)"

            # Extract status
            STATUS="IN PROGRESS"
            if printf '%s' "$LAST_HEADER" | grep -q "COMPLETE"; then
                STATUS="COMPLETE"
            fi

            # Extract timestamp and compute age
            HEADER_TS=$(printf '%s' "$LAST_HEADER" | sed -n 's/.*Session: \([^ ]*\).*/\1/p')
            AGE=""
            if [ -n "$HEADER_TS" ]; then
                HEADER_EPOCH=$(date -d "$HEADER_TS" +%s 2>/dev/null || true)
                NOW_EPOCH=$(date +%s)
                if [ -n "$HEADER_EPOCH" ]; then
                    DIFF_MIN=$(( (NOW_EPOCH - HEADER_EPOCH) / 60 ))
                    AGE="Session notes last updated: ${DIFF_MIN} minutes ago"
                fi
            fi

            CONTEXT="${CONTEXT}
  Task: ${TASK}
  Status: ${STATUS}"
            [ -n "$AGE" ] && CONTEXT="${CONTEXT}
  ${AGE}"
        else
            CONTEXT="${CONTEXT}
  No session notes for this session yet."
        fi
    else
        CONTEXT="${CONTEXT}
  No session notes file found for project '${WAL_PROJECT}'."
    fi

    # --- Recent WAL actions ---
    if [ -f "$WAL_FILE" ]; then
        RECENT=$(grep "$WAL_SESSION_ID" "$WAL_FILE" 2>/dev/null | tail -10 | "$WAL_JQ" -r '"    [" + .ts[11:19] + "] " + .phase + ": " + (.summary // .tool)' 2>/dev/null || true)
        if [ -n "$RECENT" ]; then
            CONTEXT="${CONTEXT}

  Recent actions (last 10):
${RECENT}"
        fi
    fi

    CONTEXT="${CONTEXT}

  Full session notes: claude_docs/session_notes/${WAL_PROJECT}.md"

    "$WAL_JQ" -nc --arg ctx "$CONTEXT" '{additionalContext: $ctx}'
}

_do_context 2>/dev/null || true
exit 0
