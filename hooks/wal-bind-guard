#!/bin/bash
# WAL Bind Guard — Enforces session binding and prevents cross-project file writes.
# Hook: PreToolUse (matcher: Edit|Write|MultiEdit|NotebookEdit|Read)
# Denies tool use if:
#   1. Session is unbound and multiple projects are active
#   2. File path belongs to a different project than the bound one
# Fail-open: if jq is unavailable or any error occurs, allows the operation.
# Design: docs/plans/2026-03-07-multi-project-sessions-design.md

set -euo pipefail

# Shared resolution (#262): stdin parse, workspace find, claude_docs
# containment, and registry lookup come from wal-lib.sh — never inline a copy.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
source "$SCRIPT_DIR/wal-lib.sh"

wal_read_stdin
command -v "$WAL_JQ" &>/dev/null || exit 0
wal_parse_fields
INPUT="$WAL_RAW_INPUT"
JQ="$WAL_JQ"
SESSION_ID="$WAL_SESSION_ID"
TOOL_NAME="$WAL_TOOL_NAME"

[ "$SESSION_ID" = "unknown" ] && exit 0

# --- Find workspace (traverse up to 5 levels) ---
wal_find_workspace || exit 0
WORKSPACE_FILE="$WAL_WORKSPACE_FILE"
WORKSPACE_ROOT="$WAL_WORKSPACE_ROOT"

# --- Helper: extract file path from tool input ---
_get_file_path() {
    local fp=""
    if [ "$TOOL_NAME" = "NotebookEdit" ]; then
        fp=$(printf '%s' "$INPUT" | "$JQ" -r '.tool_input.notebook_path // ""' 2>/dev/null || true)
    else
        fp=$(printf '%s' "$INPUT" | "$JQ" -r '.tool_input.file_path // ""' 2>/dev/null || true)
    fi
    printf '%s' "$fp"
}

# --- Helper: check if a file path is under any active project directory ---
_is_project_file() {
    local file="$1"
    local ws_root="$2"
    [ -z "$file" ] && return 1
    [[ "$file" != /* ]] && return 1
    while IFS= read -r proj_path; do
        local abs_proj="$ws_root/${proj_path#./}/"
        if [[ "$file" == "$abs_proj"* ]]; then
            return 0
        fi
    done < <("$JQ" -r '.projects[] | select(.active == true) | .path' "$WORKSPACE_FILE" 2>/dev/null || true)
    return 1
}

# --- Resolve claude_docs path (shared containment semantics) ---
wal_resolve_claude_docs
CLAUDE_DOCS="$WAL_CLAUDE_DOCS"

# --- Resolve bound project from registry (shared lookup) ---
wal_resolve_project
BOUND_PROJECT="$WAL_PROJECT"

# --- Executor-dispatch env fallback (#640) ---
# A subprocess spawned by hooks/executor_routing_lib.py's executor-seat dispatch
# (phase_executor's claude_cli adapter) is a fresh, unregistered
# `claude --print --no-session-persistence` session — it can never appear in
# session_registry.jsonl, so the registry lookup above always returns empty and
# Gate 1 denies it in any workspace with >1 active project, including reads of
# its OWN project's files. The dispatch code writes a claim marker file INSIDE
# its own capture dir (`.rawgentic/runs/<run>/<seat>/<attempt>/dispatch-claim.json`
# — already rooted under the dispatching project's own tree by construction,
# since only that trusted dispatch path ever creates files there) and sets
# RAWGENTIC_DISPATCH_CLAIM to its path. Trust is by PATH CONTAINMENT, never by
# trusting the env var's value as a bare project-name string: accept it ONLY
# when the registry lookup found nothing (never override a real binding), the
# claim file actually EXISTS, and its realpath resolves under a real ACTIVE
# project's own `.rawgentic/runs/` tree (a symlink or `../` escape is defeated
# by realpath canonicalization before the prefix check). Gate 2 still enforces
# the cross-project boundary using whichever project name this resolves to.
if [ -z "$BOUND_PROJECT" ] && [ -n "${RAWGENTIC_DISPATCH_CLAIM:-}" ]; then
    CLAIM_REAL=$(realpath -m "$RAWGENTIC_DISPATCH_CLAIM" 2>/dev/null || true)
    if [ -n "$CLAIM_REAL" ] && [ -f "$CLAIM_REAL" ]; then
        while IFS=$'\t' read -r _pname _ppath; do
            [ -z "$_pname" ] && continue
            _pabs=$(realpath -m "$WORKSPACE_ROOT/${_ppath#./}" 2>/dev/null || true)
            [ -z "$_pabs" ] && continue
            case "$CLAIM_REAL" in
                "$_pabs/.rawgentic/runs/"*)
                    BOUND_PROJECT="$_pname"
                    break
                    ;;
            esac
        done < <("$JQ" -r '.projects[] | select(.active == true) | "\(.name)\t\(.path)"' "$WORKSPACE_FILE" 2>/dev/null || true)
    fi
fi

# --- Gate 1: Unbound session check ---
if [ -z "$BOUND_PROJECT" ]; then
    ACTIVE_COUNT=$("$JQ" '[.projects[] | select(.active == true)] | length' "$WORKSPACE_FILE" 2>/dev/null || echo "0")
    if [ "$ACTIVE_COUNT" -gt 1 ]; then
        # Allow Read/Edit/Write for workspace-level files (not under any project dir).
        # This is needed so /rawgentic:switch can read and update
        # .rawgentic_workspace.json and session_registry.jsonl to perform the binding.
        FILE_PATH=$(_get_file_path)
        if [ "$TOOL_NAME" = "Read" ] || [ "$TOOL_NAME" = "Edit" ] || [ "$TOOL_NAME" = "Write" ]; then
            WORKSPACE_ROOT=$(cd "$(dirname "$WORKSPACE_FILE")" && pwd 2>/dev/null) || exit 0
            if ! _is_project_file "$FILE_PATH" "$WORKSPACE_ROOT"; then
                exit 0  # Workspace-level file — allow
            fi
        fi

        # Name the denied tool AND file path so a wedged bootstrap (#318 — the
        # new-project register-existing flow reads a candidate project's files
        # while still unbound) is diagnosable from the transcript, instead of an
        # opaque "not bound" the operator can't map back to a specific Read. The
        # bootstrap fix itself is skill-level (new-project binds the session to
        # the target right after registering it); this only makes the deny legible.
        # Build the JSON with jq so the tool name and file path are escaped — a
        # path with a quote/backslash must not produce malformed JSON (which the
        # runtime would drop, silently fail-opening the deny).
        ACTIVE_NAMES=$("$JQ" -r '[.projects[] | select(.active == true) | .name] | join(", ")' "$WORKSPACE_FILE" 2>/dev/null || true)
        FILE_CLAUSE=""
        [ -n "$FILE_PATH" ] && FILE_CLAUSE=" (${TOOL_NAME} of ${FILE_PATH})"
        MSG="This session isn't bound to a project yet, so ${TOOL_NAME} was denied${FILE_CLAUSE}. Multiple projects are active: ${ACTIVE_NAMES}. Ask the user which project they want to work on, then run /rawgentic:switch <name> to bind this session."
        "$JQ" -cn --arg msg "$MSG" '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny"},systemMessage:$msg}'
        exit 0
    fi
    # Single or zero active — allow (wal-context handles auto-bind)
    exit 0
fi

# --- Gate 2: Cross-project file guard ---
# Extract file path from tool input
FILE_PATH=$(_get_file_path)

# No file path or not absolute — allow
[ -z "$FILE_PATH" ] && exit 0
[[ "$FILE_PATH" != /* ]] && exit 0

# Resolve workspace root (directory containing .rawgentic_workspace.json)
WORKSPACE_ROOT=$(cd "$(dirname "$WORKSPACE_FILE")" && pwd 2>/dev/null) || {
    # Path resolution failed — fail-open, log to stderr for debugging
    echo "wal-bind-guard: could not resolve workspace root from $WORKSPACE_FILE" >&2
    exit 0
}

# Check if file is under a DIFFERENT project's directory. Own-project check
# and violation scan run in ONE jq (#268): a file under the BOUND project's
# workspace-declared path emits nothing (allow). The bound path comes from
# the WORKSPACE entry for the #265-validated bound NAME — never from the
# registry's unvalidated project_path (Step 11 catch: a stale/hand-edited
# project_path pointing at another project must not defeat the deny).
# Named delta: with (unsupported) NESTED project dirs a file under both the
# bound project and a nested other project allows via the own-check where
# the plain scan denied — no workspace nests projects.
VIOLATION=$("$JQ" -r --arg file "$FILE_PATH" --arg bound "$BOUND_PROJECT" --arg root "$WORKSPACE_ROOT" '
  ([.projects[] | select(.name == $bound) | .path] | .[0] // "") as $bp
  | if $bp != "" and ($file | startswith($root + "/" + ($bp | ltrimstr("./")) + "/"))
    then empty
    else (.projects[]
      | select(.name != $bound and .active == true)
      | .path as $p
      | ($root + "/" + ($p | ltrimstr("./")) + "/") as $abs
      | select($file | startswith($abs))
      | .name)
    end
' "$WORKSPACE_FILE" 2>/dev/null | head -1 || true)

if [ -n "$VIOLATION" ]; then
    # --- #49: cross-project allowlist exception (Gate 2 ONLY) ---
    # An opt-in workspace allowlist of glob patterns (crossProjectAllowedPaths) may relax
    # SPECIFIC paths in another active project (e.g. "docs/**", "CLAUDE.md"). Missing/empty
    # => deny-all preserved. Realpath-hardened: the file is canonicalized and MUST still
    # resolve under the target project's dir, so a symlink or `../` can't escape it.
    ALLOWLIST=$("$JQ" -r '.crossProjectAllowedPaths // [] | .[]' "$WORKSPACE_FILE" 2>/dev/null || true)
    if [ -n "$ALLOWLIST" ]; then
        TARGET_PATH=$("$JQ" -r --arg v "$VIOLATION" '.projects[] | select(.name == $v and .active == true) | .path' "$WORKSPACE_FILE" 2>/dev/null | head -1 || true)
        TARGET_ABS=$(realpath -m "$WORKSPACE_ROOT/${TARGET_PATH#./}" 2>/dev/null || true)
        FILE_REAL=$(realpath -m "$FILE_PATH" 2>/dev/null || true)
        # AC4: resolved file must still be under the (resolved) target project dir.
        if [ -n "$TARGET_ABS" ] && [ -n "$FILE_REAL" ] && [ "${FILE_REAL#"$TARGET_ABS"/}" != "$FILE_REAL" ]; then
            REL="${FILE_REAL#"$TARGET_ABS"/}"
            MATCHED=0
            while IFS= read -r _pat; do
                [ -z "$_pat" ] && continue
                # AC5: bash glob match. In `case`, `*` spans `/`, so "docs/**" matches
                # nested paths. AC8 (no "docs-extra/…" false match) holds because the
                # pattern's OWN literal prefix ("docs/") anchors it — a bare "*"/"**"
                # matches everything (documented footgun), so patterns must be specific.
                case "$REL" in
                    $_pat) MATCHED=1; break ;;
                esac
            done <<EOF_ALLOW
$ALLOWLIST
EOF_ALLOW
            if [ "$MATCHED" = "1" ]; then
                _op="write"; [ "$TOOL_NAME" = "Read" ] && _op="read"
                echo "wal-bind-guard: cross-project ${_op} to ${VIOLATION}/${REL} — allowed by crossProjectAllowedPaths" >&2
                exit 0
            fi
        fi
    fi
    # #325: build the message as a plain shell string, then let jq do all JSON
    # escaping via --arg — mirrors the Gate-1 deny at ~line 94. A raw heredoc
    # interpolating VIOLATION/BOUND_PROJECT (VIOLATION is read unvalidated from the
    # workspace .name) would malform the JSON on a `"`/`\` and silently fail-open.
    MSG="You're bound to **${BOUND_PROJECT}** but this file is in **${VIOLATION}**. Switch first with /rawgentic:switch ${VIOLATION}, or ask the user if this cross-project edit is intentional."
    "$JQ" -cn --arg msg "$MSG" '{hookSpecificOutput:{hookEventName:"PreToolUse",permissionDecision:"deny"},systemMessage:$msg}'
    exit 0
fi

# All checks passed — allow
exit 0
