#!/usr/bin/env bash
# Stop hook — Writes session end marker to session notes, never blocks.
# Guard: exits immediately for non-rawgentic sessions.
# Design: docs/plans/2026-03-06-wal-session-notes-design.md

_do_stop() {
    set -euo pipefail

    INPUT=$(cat)

    JQ="${HOME}/.local/bin/jq"
    [ -x "$JQ" ] || JQ="jq"
    command -v "$JQ" &>/dev/null || exit 0

    SESSION_ID=$(printf '%s' "$INPUT" | "$JQ" -r '.session_id // "unknown"')
    CWD=$(printf '%s' "$INPUT" | "$JQ" -r '.cwd // "."')

    [ "$SESSION_ID" = "unknown" ] && exit 0

    # --- Guard clause: not a rawgentic session ---
    WORKSPACE_FILE="$CWD/.rawgentic_workspace.json"
    [ ! -f "$WORKSPACE_FILE" ] && WORKSPACE_FILE="$CWD/../.rawgentic_workspace.json"
    [ ! -f "$WORKSPACE_FILE" ] && exit 0

    # --- Lookup project from registry ---
    REGISTRY_FILE="$CWD/claude_docs/session_registry.jsonl"
    PROJECT=""
    if [ -f "$REGISTRY_FILE" ]; then
        REG_LINE=$(grep "$SESSION_ID" "$REGISTRY_FILE" 2>/dev/null | tail -1 || true)
        if [ -n "$REG_LINE" ]; then
            PROJECT=$(printf '%s' "$REG_LINE" | "$JQ" -r '.project // ""')
        fi
    fi

    # Fallback to active workspace project
    if [ -z "$PROJECT" ]; then
        PROJECT=$("$JQ" -r '.projects[] | select(.active == true) | .name' "$WORKSPACE_FILE" 2>/dev/null || true)
    fi

    [ -z "$PROJECT" ] && exit 0

    # --- Write session end marker to notes ---
    NOTES_DIR="$CWD/claude_docs/session_notes"
    NOTES_FILE="$NOTES_DIR/${PROJECT}.md"
    TS=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

    mkdir -p "$NOTES_DIR"

    # Create notes file if missing
    if [ ! -f "$NOTES_FILE" ]; then
        printf '# Session Notes -- %s\n' "$PROJECT" > "$NOTES_FILE"
    fi

    # Append session end marker (only if no recent marker for this session)
    LAST_HEADER=$(grep "ID: ${SESSION_ID}" "$NOTES_FILE" 2>/dev/null | tail -1 || true)
    if [ -n "$LAST_HEADER" ]; then
        # Session already has a header — check if it says COMPLETE
        if printf '%s' "$LAST_HEADER" | grep -q "COMPLETE"; then
            # Already marked complete, nothing to do
            exit 0
        fi
    fi

    # Append a session end marker
    printf '\n---\n# Session: %s | ID: %s | Status: COMPLETE\n## Project: %s\n' \
        "$TS" "$SESSION_ID" "$PROJECT" >> "$NOTES_FILE"

    # Log to WAL
    WAL_FILE="$CWD/claude_docs/wal.jsonl"
    "$JQ" -nc \
        --arg ts "$TS" \
        --arg session "$SESSION_ID" \
        --arg project "$PROJECT" \
        '{ts:$ts, phase:"STOP", session:$session, project:$project, summary:"Session ended"}' \
        >> "$WAL_FILE" 2>/dev/null || true
}

_do_stop 2>/dev/null || true
exit 0
