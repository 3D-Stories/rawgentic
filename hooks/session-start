#!/usr/bin/env bash
# SessionStart hook for rawgentic plugin — detects first-run

set -euo pipefail

# Escape string for JSON embedding using bash parameter substitution.
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# Check if CLAUDE.md exists and contains the generated constants marker
CLAUDE_MD="./CLAUDE.md"
MARKER="## Project Constants (generated by /rawgentic:setup)"

if [ -f "$CLAUDE_MD" ] && grep -qF "$MARKER" "$CLAUDE_MD" 2>/dev/null; then
    # Already set up — output empty context (silent)
    context=""
else
    # First run — suggest setup
    context=$(escape_for_json "This project has not been configured with rawgentic yet. Suggest the user run /rawgentic:setup to initialize project constants and templates.")
fi

# Output context injection as JSON.
cat <<EOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${context}"
  }
}
EOF

exit 0
