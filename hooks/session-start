#!/usr/bin/env bash
# Unified SessionStart hook — WAL recovery + session notes archival + rawgentic context
# Fires on: startup, resume, clear, compact
# Design: docs/plans/2026-03-06-wal-session-notes-design.md

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
# Shared resolution (#262): workspace find + claude_docs containment come from
# wal-lib.sh — never inline a copy here.
source "$SCRIPT_DIR/wal-lib.sh"

# --- Shared utilities ---
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

# --- Read input ---
INPUT=$(cat)

# Try jq first, fall back to python3
JQ="${HOME}/.local/bin/jq"
[ -x "$JQ" ] || JQ="jq"

# EVENT_TYPE is the SessionStart *subtype* (startup/resume/clear/compact) that the
# subtype-gated sections below switch on. Claude Code delivers that subtype in the
# `.source` field; `.hook_event_name` is always the literal "SessionStart" (the
# event NAME). Read `.source` first, then fall back to `.hook_event_name` for
# legacy/test callers that put the subtype there, then to "startup". Reading
# `.hook_event_name` alone (the prior bug) made every `[ "$EVENT_TYPE" = "..." ]`
# guard always-false in production — silently disabling migration, reconciliation,
# the notes size-handler, per-project handoff, the security-staleness check, and
# the scanner bootstrap. See docs/hooks-reference / the SessionStart contract.
if command -v "$JQ" &>/dev/null; then
    CWD=$(printf '%s' "$INPUT" | "$JQ" -r '.cwd // "."')
    SESSION_ID=$(printf '%s' "$INPUT" | "$JQ" -r '.session_id // "unknown"')
    EVENT_TYPE=$(printf '%s' "$INPUT" | "$JQ" -r '.source // .hook_event_name // "startup"')
else
    # ONE python3 for all three fields (#269) — newline-delimited, read in order.
    _PARSED=$(printf '%s' "$INPUT" | python3 -c "
import sys, json
try:
    d = json.load(sys.stdin)
except Exception:
    d = {}
print(d.get('cwd', '.'))
print(d.get('session_id', 'unknown'))
print(d.get('source') or d.get('hook_event_name') or 'startup')
" 2>/dev/null || printf '.\nunknown\nstartup\n')
    { read -r CWD; read -r SESSION_ID; read -r EVENT_TYPE; } <<< "$_PARSED"
    [ -n "$CWD" ] || CWD="."
    [ -n "$SESSION_ID" ] || SESSION_ID="unknown"
fi
# Defensive: jq's // keeps an empty-string .source (only null/false fall through),
# and a malformed payload could yield empty — never leave EVENT_TYPE blank, or no
# subtype-gated section (startup/resume/...) would match.
[ -n "$EVENT_TYPE" ] || EVENT_TYPE="startup"

CONTEXT_PARTS=()

# Find workspace file (traverse up from CWD)
WAL_CWD="$CWD"
wal_find_workspace || true
WORKSPACE_FILE="$WAL_WORKSPACE_FILE"
WS_ROOT="$WAL_WORKSPACE_ROOT"

# --- Resolve claude_docs path (shared containment semantics, #262) ---
CLAUDE_DOCS=""
if [ -n "$WS_ROOT" ]; then
    wal_resolve_claude_docs
    CLAUDE_DOCS="$WAL_CLAUDE_DOCS"
fi

# =========================================================================
# SECTION 0.5: claude_docs migration to ~/claude_docs (one-time, startup)
# =========================================================================
_do_migration() {
    # DEFERRED by default. The field-read fix (above) revived the subtype gates,
    # but this section MOVES data (workspace/claude_docs -> ~/claude_docs + symlink,
    # merging into any existing ~/claude_docs). That data-layout change is opt-in so
    # it never happens as a surprise side effect of another fix. Enable deliberately
    # with RAWGENTIC_ENABLE_CLAUDE_DOCS_MIGRATION=1. See the P2 migration-decision issue.
    [ "${RAWGENTIC_ENABLE_CLAUDE_DOCS_MIGRATION:-}" = "1" ] || return 0
    [ "$EVENT_TYPE" = "startup" ] || return 0
    [ -n "$WORKSPACE_FILE" ] || return 0
    command -v "$JQ" &>/dev/null || return 0

    # Guard: already migrated
    local existing_cdp
    existing_cdp=$("$JQ" -r '.claudeDocsPath // ""' "$WORKSPACE_FILE" 2>/dev/null || true)
    [ -z "$existing_cdp" ] || return 0

    local source="$WS_ROOT/claude_docs"
    local target="$HOME/claude_docs"

    # Guard: source and target must be different paths
    local real_target
    real_target=$(realpath -m "$target" 2>/dev/null || echo "$target")
    local real_source_dir
    real_source_dir=$(realpath -m "$source" 2>/dev/null || echo "$source")
    [ "$real_source_dir" != "$real_target" ] || return 0

    # Guard: source must exist as a real directory (not a symlink)
    [ -d "$source" ] && [ ! -L "$source" ] || return 0

    # Guard: validate source is exactly workspace/claude_docs
    local real_source
    real_source=$(realpath "$source" 2>/dev/null || echo "$source")
    local expected_source
    expected_source=$(realpath "$WS_ROOT" 2>/dev/null || echo "$WS_ROOT")/claude_docs
    [ "$real_source" = "$expected_source" ] || return 0

    # Create target structure
    mkdir -p "$target/wal" "$target/session_notes" 2>/dev/null || {
        CONTEXT_PARTS+=("WARNING: claude_docs migration failed — could not create $target")
        return 0
    }

    # --- Merge registry (python3 dedup by session_id, keep latest) ---
    if [ -f "$source/session_registry.jsonl" ]; then
        if [ -f "$target/session_registry.jsonl" ]; then
            python3 -c "
import json, sys
sys.path.insert(0, sys.argv[3])
from atomic_write_lib import atomic_write_text
seen = {}
for path in sys.argv[1:3]:
    try:
        with open(path) as f:
            for line in f:
                line = line.strip()
                if not line:
                    continue
                try:
                    entry = json.loads(line)
                    sid = entry.get('session_id', '')
                    ts = entry.get('started', '')
                    key = sid
                    if key in seen:
                        if ts > seen[key][1]:
                            seen[key] = (line, ts)
                    else:
                        seen[key] = (line, ts)
                except json.JSONDecodeError:
                    pass
    except FileNotFoundError:
        pass
atomic_write_text(sys.argv[2],
                  ''.join(line + '\n' for line, _ in seen.values()))
" "$source/session_registry.jsonl" "$target/session_registry.jsonl" "$SCRIPT_DIR" 2>/dev/null || true
        else
            cp "$source/session_registry.jsonl" "$target/session_registry.jsonl" 2>/dev/null || true
        fi
    fi

    # --- Move per-project WAL files (concatenate on collision) ---
    if [ -d "$source/wal" ]; then
        for f in "$source/wal"/*.jsonl; do
            [ -f "$f" ] || continue
            local fname
            fname=$(basename "$f")
            if [ -f "$target/wal/$fname" ]; then
                cat "$f" >> "$target/wal/$fname" 2>/dev/null || true
            else
                cp "$f" "$target/wal/$fname" 2>/dev/null || true
            fi
        done
    fi

    # --- Move legacy wal.jsonl if present ---
    if [ -f "$source/wal.jsonl" ] && [ ! -f "$target/wal.jsonl" ]; then
        cp "$source/wal.jsonl" "$target/wal.jsonl" 2>/dev/null || true
    fi

    # --- Move session notes (cp -n for .md, no overwrite) ---
    if [ -d "$source/session_notes" ]; then
        for f in "$source/session_notes"/*.md; do
            [ -f "$f" ] || continue
            local fname
            fname=$(basename "$f")
            if [ ! -f "$target/session_notes/$fname" ]; then
                cp "$f" "$target/session_notes/$fname" 2>/dev/null || true
            else
                # Same-project collision: append below separator
                printf '\n---\n' >> "$target/session_notes/$fname"
                cat "$f" >> "$target/session_notes/$fname" 2>/dev/null || true
            fi
        done
        # Archive directory
        if [ -d "$source/session_notes/archive" ]; then
            mkdir -p "$target/session_notes/archive" 2>/dev/null || true
            for f in "$source/session_notes/archive"/*.jsonl; do
                [ -f "$f" ] || continue
                local fname
                fname=$(basename "$f")
                if [ -f "$target/session_notes/archive/$fname" ]; then
                    cat "$f" >> "$target/session_notes/archive/$fname" 2>/dev/null || true
                else
                    cp "$f" "$target/session_notes/archive/$fname" 2>/dev/null || true
                fi
            done
        fi
    fi

    # --- Move other top-level files (target wins if exists) ---
    for f in .current_session_id headless_suspend.json; do
        if [ -f "$source/$f" ] && [ ! -f "$target/$f" ]; then
            cp "$source/$f" "$target/$f" 2>/dev/null || true
        fi
    done

    # --- Verify target has data ---
    if [ ! -f "$target/session_registry.jsonl" ] && [ -f "$source/session_registry.jsonl" ]; then
        CONTEXT_PARTS+=("WARNING: claude_docs migration verification failed — target missing registry")
        return 0
    fi

    # --- Atomic swap: rename source to .bak, create symlink ---
    mv "$source" "${source}.bak" 2>/dev/null || {
        CONTEXT_PARTS+=("WARNING: claude_docs migration failed — could not rename source")
        return 0
    }
    ln -s "$target" "$source" 2>/dev/null || {
        # Restore on failure
        mv "${source}.bak" "$source" 2>/dev/null || true
        CONTEXT_PARTS+=("WARNING: claude_docs migration failed — could not create symlink")
        return 0
    }

    # --- Write claudeDocsPath to workspace config ---
    local tmp_ws
    tmp_ws=$(mktemp)
    "$JQ" '. + {"claudeDocsPath": "~/claude_docs"}' "$WORKSPACE_FILE" > "$tmp_ws" 2>/dev/null && \
        mv "$tmp_ws" "$WORKSPACE_FILE" 2>/dev/null || {
        rm -f "$tmp_ws" 2>/dev/null || true
        CONTEXT_PARTS+=("WARNING: claude_docs migrated to ~/claude_docs/ but failed to write claudeDocsPath to .rawgentic_workspace.json. Manually add '\"claudeDocsPath\": \"~/claude_docs\"' to the workspace config to complete migration.")
        return 0
    }

    # Update resolved path
    CLAUDE_DOCS="$target"
}
_do_migration 2>/dev/null || true

# --- Deferred .bak cleanup (from prior migration) ---
_do_bak_cleanup() {
    # Part of the deferred claude_docs migration (see _do_migration): only finishes
    # a migration that the opt-in actually performed. Gated identically so the whole
    # migration feature stays dormant as one unit.
    [ "${RAWGENTIC_ENABLE_CLAUDE_DOCS_MIGRATION:-}" = "1" ] || return 0
    [ "$EVENT_TYPE" = "startup" ] || return 0
    local bak_dir="$WS_ROOT/claude_docs.bak"
    [ -d "$bak_dir" ] || return 0
    [ -L "$WS_ROOT/claude_docs" ] || return 0

    # Merge any orphaned writes from .bak into target
    if [ -d "$bak_dir/wal" ]; then
        for f in "$bak_dir/wal"/*.jsonl; do
            [ -f "$f" ] || continue
            local fname
            fname=$(basename "$f")
            local target_f="$CLAUDE_DOCS/wal/$fname"
            if [ -f "$target_f" ]; then
                # Append orphaned writes — WAL readers tolerate duplicates
                cat "$f" >> "$target_f" 2>/dev/null || true
            else
                cp "$f" "$target_f" 2>/dev/null || true
            fi
        done
    fi

    rm -rf "$bak_dir" 2>/dev/null || true
}
_do_bak_cleanup 2>/dev/null || true

# Write session ID to discoverable file for /rawgentic:switch skill
if [ -n "$WS_ROOT" ]; then
    mkdir -p "$CLAUDE_DOCS" 2>/dev/null || true
    printf '%s' "$SESSION_ID" > "$CLAUDE_DOCS/.current_session_id" 2>/dev/null || true
fi

# Check session registry first
_registry_project=""
REGISTRY_FILE="$CLAUDE_DOCS/session_registry.jsonl"
if [ -f "$REGISTRY_FILE" ] && [ "$SESSION_ID" != "unknown" ]; then
    _registry_line=$(grep "$SESSION_ID" "$REGISTRY_FILE" 2>/dev/null | tail -1 || true)
    if [ -n "$_registry_line" ] && command -v "$JQ" &>/dev/null; then
        _registry_project=$(printf '%s' "$_registry_line" | "$JQ" -r '.project // ""' 2>/dev/null || true)
    fi
fi
# Containment (#265): session-start builds WAL/archive paths from this name
# WITHOUT going through wal_resolve_project — validate it here once so every
# downstream interpolation (_do_wal_ops, _do_archive_context) is covered.
if [ -n "$_registry_project" ] && ! wal_validate_project_name "$_registry_project"; then
    _registry_project=""
fi

# =========================================================================
# SECTION 0: Project Directory Reconciliation (startup/resume only)
# =========================================================================
_do_reconciliation() {
    [ "$EVENT_TYPE" = "startup" ] || [ "$EVENT_TYPE" = "resume" ] || return 0
    [ -z "$WORKSPACE_FILE" ] && return 0

    if ! command -v python3 &>/dev/null; then
        return 0
    fi

    # Check each active project's directory exists
    MISSING_PROJECTS=$(python3 -c "
import json, os
ws = json.load(open('${WORKSPACE_FILE}'))
ws_dir = os.path.dirname(os.path.abspath('${WORKSPACE_FILE}'))
missing = []
for p in ws.get('projects', []):
    if p.get('active'):
        abs_path = os.path.normpath(os.path.join(ws_dir, p['path']))
        if not os.path.isdir(abs_path):
            missing.append(f\"{p['name']}|{p['path']}\")
for m in missing:
    print(m)
" 2>/dev/null || true)

    if [ -n "$MISSING_PROJECTS" ]; then
        # Deactivate missing projects in workspace config
        # Pass missing names via env var to avoid shell injection
        MISSING_NAMES=$(echo "$MISSING_PROJECTS" | cut -d'|' -f1 | paste -sd',' -)
        MISSING_NAMES="$MISSING_NAMES" python3 -c "
import json, os
ws_path = os.environ.get('WORKSPACE_FILE', '${WORKSPACE_FILE}')
missing_names = set(os.environ.get('MISSING_NAMES', '').split(','))
with open(ws_path) as f:
    ws = json.load(f)
for p in ws.get('projects', []):
    if p['name'] in missing_names:
        p['active'] = False
with open(ws_path, 'w') as f:
    json.dump(ws, f, indent=2)
" 2>/dev/null || true

        # Build context message
        while IFS='|' read -r name path; do
            CONTEXT_PARTS+=("Project **${name}** is registered but directory \`${path}\` is missing. Was it removed, or did setup crash? Reply 'remove' to deregister, or 'setup' to re-run \`/rawgentic:new-project ${name}\`.")
        done <<< "$MISSING_PROJECTS"
    fi
}
_do_reconciliation 2>/dev/null || true

# =========================================================================
# SECTION 1: WAL Operations (always runs)
# =========================================================================
_do_wal_ops() {
    if ! command -v "$JQ" &>/dev/null; then
        return 0
    fi

    # Determine WAL file: per-project if bound, fall back to legacy
    WAL_FILE=""
    if [ -n "$_registry_project" ]; then
        WAL_FILE="$CLAUDE_DOCS/wal/${_registry_project}.jsonl"
    fi
    # Fall back to legacy WAL if per-project doesn't exist
    if [ -z "$WAL_FILE" ] || [ ! -f "$WAL_FILE" ]; then
        WAL_FILE="$CLAUDE_DOCS/wal.jsonl"
    fi
    [ -f "$WAL_FILE" ] || return 0

    # Sanitize malformed lines
    CLEAN_FILE=$(mktemp)
    "$JQ" -c '.' "$WAL_FILE" 2>/dev/null > "$CLEAN_FILE" || true
    [ -s "$CLEAN_FILE" ] || { rm -f "$CLEAN_FILE"; return 0; }

    # WAL Rotation (>5000 lines)
    LINE_COUNT=$(wc -l < "$CLEAN_FILE")
    if [ "$LINE_COUNT" -gt 5000 ]; then
        CUTOFF=$(date -u -d '7 days ago' +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || date -u -v-7d +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null || printf '')
        if [ -n "$CUTOFF" ]; then
            ROTATED=$("$JQ" -sc --arg cutoff "$CUTOFF" '
                (group_by(.tool_use_id)
                 | map(select(
                     (map(.phase) | index("INTENT")) != null
                     and (map(.phase) | index("DONE")) == null
                     and (map(.phase) | index("FAIL")) == null
                   ))
                 | map(.[0].tool_use_id)
                ) as $incomplete_ids
                |
                [.[] | select(.ts >= $cutoff or (.tool_use_id as $id | $incomplete_ids | index($id) != null))]
                | .[]
            ' "$CLEAN_FILE" 2>/dev/null) || true
            if [ -n "$ROTATED" ]; then
                printf '%s\n' "$ROTATED" > "$CLEAN_FILE"
                cp "$CLEAN_FILE" "$WAL_FILE"
            fi
        fi
    fi

    # Find incomplete operations
    INCOMPLETE=$("$JQ" -sc '
        group_by(.tool_use_id)
        | map(
            select(
              (map(.phase) | index("INTENT")) != null
              and (map(.phase) | index("DONE")) == null
              and (map(.phase) | index("FAIL")) == null
            )
            | map(select(.phase == "INTENT"))[0]
          )
        | .[]
    ' "$CLEAN_FILE" 2>/dev/null) || true

    rm -f "$CLEAN_FILE"

    if [ -n "$INCOMPLETE" ]; then
        COUNT=$(printf '%s\n' "$INCOMPLETE" | wc -l)
        SUMMARY=$(printf '%s\n' "$INCOMPLETE" | "$JQ" -r '"  - [" + .ts + "] " + .tool + ": " + .summary' 2>/dev/null | head -20)
        CONTEXT_PARTS+=("WAL RECOVERY: Found $COUNT incomplete operation(s) from previous session(s):
$SUMMARY
Review these and determine if any recovery action is needed.")
    fi
}
_do_wal_ops 2>/dev/null || true

# =========================================================================
# SECTION 2: Notes Size Handler (startup + compact events)
# =========================================================================
# Trims session notes exceeding 800 lines to keep the most recent 200.
# This is the primary growth control for session notes files.
# Runs on compact (mid-session safety net) and on startup (fallback).
_do_size_handler() {
    [ "$EVENT_TYPE" = "startup" ] || [ "$EVENT_TYPE" = "compact" ] || return 0

    NOTES_DIR="$CLAUDE_DOCS/session_notes"
    [ -d "$NOTES_DIR" ] || return 0

    # ONE invocation for all notes files (#269): the handler accepts multiple
    # paths and isolates per-file failures internally, so startup cost no
    # longer scales with project count.
    local _notes=()
    for notes_file in "$NOTES_DIR"/*.md; do
        [ -f "$notes_file" ] || continue
        _notes+=("$notes_file")
    done
    [ "${#_notes[@]}" -gt 0 ] || return 0
    python3 "$SCRIPT_DIR/notes-size-handler.py" "${_notes[@]}" \
        --session-id "$SESSION_ID" >/dev/null 2>&1 || true
}
_do_size_handler 2>/dev/null || true

# =========================================================================
# (Former SECTION 2b, archive context injection, removed in #269: its helper
# script was deleted back in #57, so the whole section was a dead path — two
# spawns per startup that always failed silently. The memorypalace plugin
# owns archive context injection now.)
# =========================================================================
# SECTION 2e: Per-Project Handoff (startup/resume/clear, bound sessions)
# =========================================================================
# rawgentic-workspace projects all share one CLAUDE_PROJECT_DIR (the workspace
# root), so the generic remember plugin's workspace-level handoff
# (.remember/remember.md) cannot separate them. Give each BOUND project its own
# handoff at claude_docs/session_notes/<project>.handoff.md: inject it as a
# briefing on the fresh-context events (startup/resume/clear, NOT compact —
# compact preserves context) and surface it as the write target. It is
# PERSISTENT (not consumed-on-read like the remember plugin), so a crash before
# the next handoff is written never loses it; it is overwritten on next write.
# Size is capped (RAWGENTIC_HANDOFF_MAX_CHARS, default 8000) to bound injection.
_do_project_handoff() {
    case "$EVENT_TYPE" in startup|resume|clear) ;; *) return 0 ;; esac
    [ -n "$_registry_project" ] || return 0
    [ -n "$CLAUDE_DOCS" ] || return 0

    # Path-safety: the project name comes from the (locally-written) session
    # registry and is used as a file-path component. Reject anything that isn't a
    # plain project name — no path separators, no traversal, no leading dot/dash —
    # so a corrupt/tampered registry can never read outside session_notes/.
    case "$_registry_project" in
        .*|-*|*..*|*[!A-Za-z0-9._-]*) return 0 ;;
    esac

    local handoff_file="$CLAUDE_DOCS/session_notes/${_registry_project}.handoff.md"
    local note="this per-project handoff supersedes the workspace-level remember-plugin handoff"

    # Fold the read into the guard so an existing-but-unreadable file falls
    # through to the write-target hint rather than silently emitting nothing.
    local content
    if [ -f "$handoff_file" ] && [ -s "$handoff_file" ] && content=$(cat "$handoff_file" 2>/dev/null); then
        local max="${RAWGENTIC_HANDOFF_MAX_CHARS:-8000}"
        case "$max" in ''|*[!0-9]*) max=8000 ;; esac
        if [ "${#content}" -gt "$max" ]; then
            content="${content:0:$max}

[handoff truncated to ${max} chars — full text in ${handoff_file}]"
        fi
        CONTEXT_PARTS+=("RAWGENTIC HANDOFF — ${_registry_project} (from ${handoff_file}; ${note} — overwrite this file with the next handoff):

${content}")
    else
        CONTEXT_PARTS+=("RAWGENTIC HANDOFF — ${_registry_project}: no readable handoff yet. Write the next handoff for this project to \`${handoff_file}\` (per-project; ${note}).")
    fi
}
_do_project_handoff 2>/dev/null || true

# =========================================================================
# SECTION 2c: Security Pattern Staleness Check (startup/resume only)
# =========================================================================
_do_security_staleness_check() {
    [ "$EVENT_TYPE" = "startup" ] || [ "$EVENT_TYPE" = "resume" ] || return 0

    # Allow env var override for testing; default to standard install path
    local official_base="${OFFICIAL_SECURITY_PLUGIN_DIR:-${HOME}/.claude/plugins/marketplaces/claude-plugins-official}"
    local pattern_file="$official_base/plugins/security-guidance/hooks/security_reminder_hook.py"

    # If official plugin not installed, skip silently
    [ -f "$pattern_file" ] || return 0

    # Compute hash of official pattern file
    local current_hash
    current_hash=$(sha256sum "$pattern_file" 2>/dev/null | cut -d' ' -f1) || return 0
    [ -n "$current_hash" ] || return 0

    # Read stored hash from marker (allow env var override for testing)
    local marker_dir="${SECURITY_SYNC_MARKER_DIR:-$SCRIPT_DIR}"
    local marker_file="$marker_dir/.last-security-sync-hash"
    local stored_hash=""
    if [ -f "$marker_file" ]; then
        stored_hash=$(cat "$marker_file" 2>/dev/null) || true
    fi

    # Compare — warn if stale or marker missing
    if [ "$current_hash" != "$stored_hash" ]; then
        CONTEXT_PARTS+=("⚠ Security patterns may be outdated. Run /rawgentic:sync-security-patterns")
    fi
}
_do_security_staleness_check 2>/dev/null || true

# =========================================================================
# SECTION 2d: Security Scanner Bootstrap (startup|resume, opt-out, self-healing)
# =========================================================================
# WF2 Step 11.5 + WF9 shell out to real scanners (gitleaks/semgrep/osv-scanner/
# trivy/pip-audit). Delegate to hooks/scanner_bootstrap.py, which re-checks
# presence each eligible session, installs only what's missing IN THE BACKGROUND
# (this hook has a 10s budget), throttles repeat attempts, and ALWAYS writes a
# timestamped status file (~/.rawgentic/scanner-status.json) so a no-fire/failed
# install is visible instead of looking like "all clean". Re-checking each
# session also means a scanner added by a plugin update is installed on the next
# session with no version bookkeeping. Opt-outs (RAWGENTIC_SKIP_SCANNER_INSTALL=1
# / "installScanners": false) and headless are honored inside the helper. Runs on
# startup|resume — NOT clear/compact — because a resume-heavy workflow would
# otherwise rarely hit a fresh startup (the original startup-only gate).
_do_scanner_bootstrap() {
    case "$EVENT_TYPE" in startup|resume) ;; *) return 0 ;; esac
    command -v python3 &>/dev/null || return 0
    local bootstrap="$SCRIPT_DIR/scanner_bootstrap.py"
    [ -f "$bootstrap" ] || return 0

    local _out
    if [ -n "$WORKSPACE_FILE" ]; then
        _out=$(python3 "$bootstrap" --event "$EVENT_TYPE" --workspace "$WORKSPACE_FILE" 2>/dev/null || true)
    else
        _out=$(python3 "$bootstrap" --event "$EVENT_TYPE" 2>/dev/null || true)
    fi
    [ -n "$_out" ] && CONTEXT_PARTS+=("$_out")
}
_do_scanner_bootstrap 2>/dev/null || true

# =========================================================================
# SECTION 2f: Post-Update Feature Reconcile (startup|resume)
# =========================================================================
# When the plugin version changes, turn on new opt-OUT features by default
# (honoring recorded opt-outs), leave headless opt-in, and nudge the user to run
# /rawgentic:setup for answer-required features (WF5/adversarialReview). Delegates
# to hooks/post_update_reconcile.py, which records the reconciled version
# per-workspace (in claude_docs) so it runs ONCE per version.
# Runs BOTH passes in one process (#269): the version reconcile plus the #234
# per-project config-staleness nudge (each ACTIVE project's unconfigured-feature
# gaps once per (project, version), independent of the reconcile marker).
# Advisory, non-blocking, fail-open; each pass is isolated inside the helper.
_do_post_update_reconcile() {
    case "$EVENT_TYPE" in startup|resume) ;; *) return 0 ;; esac
    command -v python3 &>/dev/null || return 0
    [ -n "$WORKSPACE_FILE" ] || return 0
    [ -n "$CLAUDE_DOCS" ] || return 0
    local reconcile="$SCRIPT_DIR/post_update_reconcile.py"
    [ -f "$reconcile" ] || return 0

    local _out
    _out=$(python3 "$reconcile" --session-start --workspace "$WORKSPACE_FILE" --state-dir "$CLAUDE_DOCS" 2>/dev/null || true)
    [ -n "$_out" ] && CONTEXT_PARTS+=("$_out")
}
_do_post_update_reconcile 2>/dev/null || true

# =========================================================================
# SECTION 3: Rawgentic Workspace Context (always runs)
# =========================================================================
if [ -z "$WORKSPACE_FILE" ]; then
    CONTEXT_PARTS+=("No rawgentic workspace found. Run /rawgentic:new-project to get started.")
else
    # ONE python3 for validate + count + bound-info/summary (#269 — was four).
    # The registry project name is passed via argv, never interpolated into
    # code. Output is a single machine-parseable line the case below routes on.
    WS_STATE=$(python3 -c "
import json, sys
ws_file, bound = sys.argv[1], sys.argv[2]
try:
    d = json.load(open(ws_file))
except Exception:
    print('CORRUPT'); sys.exit(0)
projects = d.get('projects', [])
if not projects:
    print('EMPTY'); sys.exit(0)
if bound:
    for p in projects:
        if p.get('name') == bound:
            print(f\"BOUND|{p['name']}|{p['path']}|{p.get('configured', False)}|{p.get('active', False)}\")
            sys.exit(0)
    print('BOUND-MISSING'); sys.exit(0)
active = [p for p in projects if p.get('active')]
if not active:
    print('NONE')
elif len(active) == 1:
    p = active[0]
    conf = 'True' if p.get('configured') else 'False'
    print(f\"SINGLE|{p['name']}|{p['path']}|{conf}\")
else:
    print('MULTI|' + ', '.join(p['name'] for p in active))
" "$WORKSPACE_FILE" "${_registry_project:-}" 2>/dev/null || echo "CORRUPT")

    case "${WS_STATE%%|*}" in
        CORRUPT)
            CONTEXT_PARTS+=("Rawgentic workspace file is corrupted. Run /rawgentic:new-project to regenerate, or fix .rawgentic_workspace.json manually.")
            ;;
        EMPTY)
            CONTEXT_PARTS+=("Rawgentic workspace exists but no projects registered. Run /rawgentic:new-project.")
            ;;
        BOUND)
            IFS='|' read -r _ ACTIVE_NAME ACTIVE_PATH CONFIGURED IS_ACTIVE <<< "$WS_STATE"
            if [ "$EVENT_TYPE" = "resume" ]; then
                if [ "$IS_ACTIVE" = "True" ]; then
                    CONTEXT_PARTS+=("Resuming work on project: **${ACTIVE_NAME}** (${ACTIVE_PATH}).")
                else
                    CONTEXT_PARTS+=("Your previous session was bound to **${ACTIVE_NAME}**, but that project is no longer active (directory may have been removed).")
                fi
            else
                if [ "$CONFIGURED" = "True" ]; then
                    CONTEXT_PARTS+=("Active project: ${ACTIVE_NAME} (${ACTIVE_PATH}).")
                else
                    CONTEXT_PARTS+=("Active project: ${ACTIVE_NAME} (${ACTIVE_PATH}). Config missing -- run /rawgentic:setup.")
                fi
            fi
            ;;
        BOUND-MISSING)
            # Bound name not in workspace — same silent outcome as the old
            # per-branch code (its loop simply printed nothing).
            ;;
        NONE)
            CONTEXT_PARTS+=("Rawgentic workspace has projects but none is active. Run /rawgentic:switch to select one.")
            ;;
        SINGLE)
            IFS='|' read -r _ ACTIVE_NAME ACTIVE_PATH CONFIGURED <<< "$WS_STATE"
            if [ "$CONFIGURED" = "True" ]; then
                CONTEXT_PARTS+=("Active project: ${ACTIVE_NAME} (${ACTIVE_PATH}).")
            else
                CONTEXT_PARTS+=("Active project: ${ACTIVE_NAME} (${ACTIVE_PATH}). Config missing -- run /rawgentic:setup.")
            fi
            ;;
        MULTI)
            NAMES="${WS_STATE#MULTI|}"
            CONTEXT_PARTS+=("Multiple projects active: ${NAMES}. Use /rawgentic:switch <name> to bind this session to a project.")
            ;;
    esac
fi

# =========================================================================
# SECTION 3b: Headless mode detection
# =========================================================================
if [ "${RAWGENTIC_HEADLESS:-}" = "1" ]; then
    # Check if the active project allows headless mode
    # Default to false (deny) — must be explicitly set to true by the jq check below
    HEADLESS_ALLOWED=false
    if [ -n "${WORKSPACE_FILE:-}" ] && command -v "$JQ" &>/dev/null; then
        # Resolve the active project name (from registry or single-active)
        _HEADLESS_PROJECT=""
        if [ -n "${SESSION_ID:-}" ] && [ -f "${CLAUDE_DOCS:-${WS_ROOT:-$CWD}/claude_docs}/session_registry.jsonl" ]; then
            _REG_LINE=$(grep "$SESSION_ID" "${CLAUDE_DOCS:-${WS_ROOT:-$CWD}/claude_docs}/session_registry.jsonl" 2>/dev/null | tail -1 || true)
            if [ -n "$_REG_LINE" ]; then
                _HEADLESS_PROJECT=$(printf '%s' "$_REG_LINE" | "$JQ" -r '.project // ""' 2>/dev/null || true)
            fi
        fi
        if [ -z "$_HEADLESS_PROJECT" ]; then
            _HEADLESS_PROJECT=$("$JQ" -r '[.projects[] | select(.active == true) | .name] | first // ""' "$WORKSPACE_FILE" 2>/dev/null || true)
        fi

        if [ -n "$_HEADLESS_PROJECT" ]; then
            # headlessEnabled accepts two shapes (#165 AC5):
            #   bool  — legacy: true allows any trigger
            #   object— {"enabled": bool, "triggers": [..], "auth": ".."}
            #           absent `triggers` = any trigger; a present list requires
            #           $RAWGENTIC_HEADLESS_TRIGGER membership (fail closed on
            #           unset env or malformed list)
            # Verdict is one of: allowed | trigger | disabled
            _HEADLESS_VERDICT=$("$JQ" -r --arg name "$_HEADLESS_PROJECT" \
                --arg trigger "${RAWGENTIC_HEADLESS_TRIGGER:-}" '
                [.projects[] | select(.name == $name)][0].headlessEnabled as $h
                | if $h == true then "allowed"
                  elif ($h | type) == "object" then
                      if ($h.enabled // false) != true then "disabled"
                      elif ($h | has("triggers") | not) then "allowed"
                      elif (($h.triggers | type) == "array"
                            and $trigger != ""
                            and ($h.triggers | index($trigger)) != null)
                          then "allowed"
                      else "trigger"
                      end
                  else "disabled"
                  end' \
                "$WORKSPACE_FILE" 2>/dev/null || echo "disabled")
            case "$_HEADLESS_VERDICT" in
                allowed)
                    HEADLESS_ALLOWED=true
                    ;;
                trigger)
                    # Deliberately do NOT echo the trigger env value: it is
                    # attacker-shaped input (on an Actions runner it may derive
                    # from event data) and this message lands in
                    # additionalContext — the model's instruction channel. Any
                    # echo, even charset-stripped, hands the deny path a
                    # rider for injected text (8a F1).
                    CONTEXT_PARTS+=("HEADLESS MODE BLOCKED: Project '${_HEADLESS_PROJECT}' allows headless mode, but the current RAWGENTIC_HEADLESS_TRIGGER value is not in the headlessEnabled.triggers allowlist (or is unset). Refusing to execute workflow skills — exit immediately.")
                    ;;
                *)
                    CONTEXT_PARTS+=("HEADLESS MODE BLOCKED: Project '${_HEADLESS_PROJECT}' does not have headless mode enabled. Set headlessEnabled: true in .rawgentic_workspace.json for this project (via /rawgentic:setup) to allow autonomous agent execution. Refusing to execute workflow skills — exit immediately.")
                    ;;
            esac
        fi
    fi

    # If jq was absent and we couldn't check headlessEnabled, add a BLOCKED message
    if [ "$HEADLESS_ALLOWED" = false ] && [ ${#CONTEXT_PARTS[@]} -gt 0 ]; then
        # Check if a BLOCKED message was already added by the jq-present path
        _HAS_BLOCKED=false
        for _part in "${CONTEXT_PARTS[@]}"; do
            if printf '%s' "$_part" | grep -q "HEADLESS MODE BLOCKED"; then
                _HAS_BLOCKED=true
                break
            fi
        done
        if [ "$_HAS_BLOCKED" = false ]; then
            CONTEXT_PARTS+=("HEADLESS MODE BLOCKED: Cannot verify headlessEnabled for this project (jq not available or project not found). Refusing to execute workflow skills in headless mode — exit immediately.")
        fi
    fi

    if [ "$HEADLESS_ALLOWED" = true ]; then
        CONTEXT_PARTS+=("HEADLESS MODE active. User interaction points must use the <headless-interaction> protocol: post structured comment to GitHub issue, add rawgentic:ai-waiting label, write suspend state, and exit cleanly.")
    fi

    # Stale suspend file check — only when headless is allowed
    SUSPEND_FILE="${CLAUDE_DOCS:-${WS_ROOT:-$CWD}/claude_docs}/headless_suspend.json"
    if [ "$HEADLESS_ALLOWED" = true ] && [ -f "$SUSPEND_FILE" ] && command -v "$JQ" &>/dev/null; then
        SUSPEND_SESSION=$("$JQ" -r '.session_id // ""' "$SUSPEND_FILE" 2>/dev/null || true)
        SUSPEND_AT=$("$JQ" -r '.suspended_at // ""' "$SUSPEND_FILE" 2>/dev/null || true)

        # TTL check: auto-delete suspend files older than 24 hours
        STALE_BY_TTL=false
        if [ -n "$SUSPEND_AT" ]; then
            SUSPEND_EPOCH=$(date -d "$SUSPEND_AT" +%s 2>/dev/null || echo 0)
            NOW_EPOCH=$(date +%s)
            AGE_HOURS=$(( (NOW_EPOCH - SUSPEND_EPOCH) / 3600 ))
            if [ "$AGE_HOURS" -ge 24 ]; then
                STALE_BY_TTL=true
            fi
        fi

        if [ "$STALE_BY_TTL" = true ]; then
            # Auto-delete: TTL expired (>24h)
            rm -f "$SUSPEND_FILE" 2>/dev/null || true
            CONTEXT_PARTS+=("Cleaned up stale headless suspend file (>24h old). Previous headless session is assumed abandoned.")
        elif [ -n "$SUSPEND_SESSION" ] && [ "$SUSPEND_SESSION" != "$SESSION_ID" ]; then
            # Warn: different session but not TTL-expired
            SUSPEND_STEP=$("$JQ" -r '.step // "unknown"' "$SUSPEND_FILE" 2>/dev/null || true)
            SUSPEND_ISSUE=$("$JQ" -r '.issue // "unknown"' "$SUSPEND_FILE" 2>/dev/null || true)
            CONTEXT_PARTS+=("WARNING: Stale headless suspend file found from a previous session (issue #${SUSPEND_ISSUE}, step ${SUSPEND_STEP}). This file may need cleanup. Delete ${SUSPEND_FILE} if the previous session is no longer active.")
        fi
    fi
fi

# Check for SUSPEND WAL entries and adjust recovery messaging (only when headless allowed)
if [ "${RAWGENTIC_HEADLESS:-}" = "1" ] && [ "${HEADLESS_ALLOWED:-true}" = true ] && [ -n "${WAL_FILE:-}" ] && [ -f "${WAL_FILE:-}" ] && command -v "$JQ" &>/dev/null; then
    HAS_SUSPEND=$("$JQ" -r 'select(.phase == "SUSPEND")' "$WAL_FILE" 2>/dev/null | tail -1 || true)
    if [ -n "$HAS_SUSPEND" ]; then
        CONTEXT_PARTS+=("Previous session was SUSPENDED awaiting user input (not crashed). Resume normally — conversation context is preserved via --resume.")
    fi
fi

# =========================================================================
# SECTION 4: Emit combined context
# =========================================================================
if [ ${#CONTEXT_PARTS[@]} -eq 0 ]; then
    exit 0
fi

# Join all context parts with double newline
COMBINED=""
for part in "${CONTEXT_PARTS[@]}"; do
    if [ -n "$COMBINED" ]; then
        COMBINED="${COMBINED}

${part}"
    else
        COMBINED="$part"
    fi
done

ESCAPED=$(escape_for_json "$COMBINED")
cat <<HOOKEOF
{
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${ESCAPED}"
  }
}
HOOKEOF
