# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/

# Node (if any tooling is added later)
node_modules/

# Python
__pycache__/
*.pyc

# Environment
.env
.env.*

# Claude Code local state (should not be in the plugin repo)
.claude/settings.local.json
claude_docs/
.rawgentic_workspace.json

# WF2 Step 11 diff-review temp files (crash-recovery backstop; normally cleaned on exit)
.rawgentic-diff-review-*.patch
.rawgentic-diff-findings-*.json

# WF2 per-branch review-state pointers (#231 AC2): local, git-excluded bookkeeping —
# never committed into a feature PR. `write_review_state` also adds `.rawgentic/` to a
# repo's `.git/info/exclude` at runtime for app repos that lack this line.
.rawgentic/review-state/*.json

# Vendored external command copies (#194): third-party prompt content — a durable
# local copy, never committed (redistribution/licensing). See docs/external-references.md
.rawgentic-vendored/
