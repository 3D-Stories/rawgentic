# OS
.DS_Store
Thumbs.db

# Editors
*.swp
*.swo
*~
.idea/
.vscode/

# Node (if any tooling is added later)
node_modules/

# Python
__pycache__/
*.pyc

# Environment
.env
.env.*

# Claude Code local state (should not be in the plugin repo)
.claude/settings.local.json
claude_docs/
.rawgentic_workspace.json

# WF2 Step 11 diff-review temp files (crash-recovery backstop; normally cleaned on exit)
.rawgentic-diff-review-*.patch
.rawgentic-diff-findings-*.json

# WF2 per-branch review-state pointers (#231 AC2): local, git-excluded bookkeeping —
# never committed into a feature PR. `write_review_state` also adds `.rawgentic/` to a
# repo's `.git/info/exclude` at runtime for app repos that lack this line.
.rawgentic/review-state/*.json

# #427: executor-routing capture + quota-permit dirs (routed-seat run records / receipts /
# provider-reported observations / inter-process permits). Tracked here — NOT only in the
# checkout-local .git/info/exclude — so a fresh clone or CI never commits captured prompts/obs.
/.rawgentic/runs/
/.rawgentic/runtime/

# Vendored external command copies (#194): third-party prompt content — a durable
# local copy, never committed (redistribution/licensing). See docs/external-references.md
.rawgentic-vendored/

# Workflow-run by-products (owner decision 2026-07-20, epic #475 run): review reports
# and bench raw output stay local — they accumulate per run and are not release
# content. Already-tracked historical files remain tracked (gitignore only hides new
# untracked ones). docs/measurements/run_records.jsonl stays COMMITTED (#92/#93).
docs/reviews/
docs/measurements/bakeoff_results.jsonl
