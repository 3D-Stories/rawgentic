{
  "version": 1,
  "project": {
    "name": "rawgentic",
    "type": "library",
    "description": "9 SDLC workflow skills + 9 workspace management + 1 planning skill + 2 security skills + hooks for Claude Code with quality gates, code review, and deployment verification"
  },
  "repo": {
    "provider": "github",
    "fullName": "3D-Stories/rawgentic",
    "defaultBranch": "main"
  },
  "protectionLevel": "sandbox",
  "techStack": ["bash", "markdown", "python"],
  "laneImplExtensions": [".md"],
  "testing": {
    "frameworks": [
      {
        "name": "pytest",
        "type": "integration",
        "command": "pytest tests/ -v",
        "configFile": null,
        "testDir": "tests"
      }
    ]
  },
  "ci": {
    "provider": "github-actions",
    "workflowDir": ".github/workflows"
  },
  "documentation": {
    "primaryFiles": ["README.md", "docs/", "LICENSE"],
    "format": "markdown"
  },
  "phaseExecutorTable": {"version": 1, "file": null},
  "telemetryAlerts": {"version": 1},
  "custom": {}
}
